merge_cells <- function(mat, c1, c2){
  merged = mat[c1,]
  for(i in 1:length(merged)){ 
    if( is.na(mat[c1,i]) & !is.na(mat[c2,i] ) ) {
      merged[i] = mat[c2,i]
    }  
    if(  !is.na(mat[c1,i]) & !is.na(mat[c2,i]) & (mat[c1,i] != mat[c2,i]  ) ){
      print("ERROR!")
    }
  }
  return(merged)
}

