count_freq <- function(data,list){
  freq = plyr::count(data)
  nmax= length(list)
  res = matrix(0, nrow=nmax, ncol=1 )
  rownames(res) = list
  m = match(list, freq[,1])
  f.r = !is.na(m)
  f.f = m[f.r]
  res[f.r,1] = freq[f.f,2]
  return(res)
}

